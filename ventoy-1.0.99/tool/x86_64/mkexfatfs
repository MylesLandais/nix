#!/usr/bin/env bash
set -euo pipefail

label=""
device=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -V|--version)
      mkfs.exfat -V >/dev/null 2>&1 || true
      echo "mkexfatfs shim using mkfs.exfat"
      exit 0
      ;;
    -n)
      label="${2:-}"
      shift 2
      ;;
    -s)
      shift 2
      ;;
    -*)
      shift
      ;;
    *)
      device="$1"
      shift
      ;;
  esac
done

[[ -n "$device" ]] || exit 1

if [[ -n "$label" ]]; then
  exec mkfs.exfat -L "$label" "$device"
else
  exec mkfs.exfat "$device"
fi
