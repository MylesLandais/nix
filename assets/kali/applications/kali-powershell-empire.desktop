[Desktop Entry]
Name=powershell-empire
Comment=PowerShell and Python post-exploitation agent
Exec=/usr/share/kali-menu/exec-in-shell "powershell-empire server"
Icon=kali-powershell-empire
StartupNotify=false
Terminal=true
Type=Application
Categories=kali-command-and-control
X-Kali-Package=powershell-empire
